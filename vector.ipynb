   "source": [
    "@classmethod\n",
    "def frombytes(cls, octest):\n",
    "    typecode = chr(octest[0])\n",
    "    memv = memoryview(octest[:1]).cast(typecode)\n",
    "    return cls(*memv)"
   ]
